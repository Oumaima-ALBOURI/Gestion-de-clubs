<title>Clubs Universitaires</title>

<style>

header {
  background: linear-gradient(135deg, #60a5fa, #34d399);
  color: white;
  text-align: center;
  padding: 90px 20px;
  border-bottom-left-radius: 40px;
  border-bottom-right-radius: 40px;
  box-shadow: 0 10px 30px rgba(0,0,0,0.15);
  font-family: 'Poppins', sans-serif;
}

/* TITRE PRINCIPAL */
header h1 {
  margin: 0;
  font-size: 3.5em;
  font-weight: 800;
  letter-spacing: 2px;
  text-transform: uppercase;
  font-family: 'Montserrat', sans-serif;
  text-shadow: 0 3px 10px rgba(0,0,0,0.25);
  animation: fadeIn 1.5s ease;
}

/* SOUS-TITRE */
header p {
  font-size: 1.2em;
  margin-top: 15px;
  opacity: 0.95;
  font-weight: 300;
}

/* Animation */
@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(-25px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}


/* =========================
   SECTION CLUBS
   ========================= */

.clubs-container {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 25px;
  padding: 40px;
}

/* =========================
   CARTE CLUB
   ========================= */

.club-card {
  background: white;
  width: 260px;
  border-radius: 15px;
  box-shadow: 0 6px 15px rgba(0,0,0,0.1);
  overflow: hidden;
  text-align: center;
  transition: 0.3s;
}

.club-card:hover {
  transform: translateY(-8px);
  box-shadow: 0 10px 25px rgba(0,0,0,0.2);
}

/* Conteneur image fixe — évite les déformations */
.club-card .img-wrapper {
  width: 100%;
  height: 160px;
  overflow: hidden;
  background-color: #e2e8f0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.club-card .img-wrapper img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  display: block;
  transition: transform 0.4s ease;
}

/* Zoom doux sur l'image au survol */
.club-card:hover .img-wrapper img {
  transform: scale(1.06);
}

/* Emoji affiché si l'image ne charge pas */
.club-card .img-wrapper .emoji-placeholder {
  font-size: 3.5em;
  display: none;
}

/* TITRE */
.club-card h3 {
  color: linear-gradient(135deg, #60a5fa, #34d399);
  margin: 12px 10px 4px;
  font-size: 1em;
}

/* DESCRIPTION */
.club-card p {
  font-size: 14px;
  color: #555;
  padding: 0 14px;
  margin-bottom: 4px;
}

/* BOUTON */
.club-card a.btn {
  display: inline-block;
  margin: 10px 0 16px;
  padding: 8px 22px;
  background: linear-gradient(135deg, #60a5fa, #34d399);
  color: white;
  text-decoration: none;
  border-radius: 20px;
  transition: 0.3s;
  font-size: 0.9em;
}

.club-card a.btn:hover {
  opacity: 0.85;
  transform: scale(1.04);
}

/* =========================
   SECTION INFO
   ========================= */

.why {
  text-align: center;
  padding: 50px 20px;
  background: #f1f5f9;
}

.why h2 {
  color:linear-gradient(135deg, #60a5fa, #34d399);
  font-size: 1.7em;
  margin-bottom: 12px;
}

.why p {
  max-width: 600px;
  margin: auto;
  color: #555;
  line-height: 1.7;
}

/* =========================
   FOOTER
   ========================= */

.footer {
  background: linear-gradient(135deg, #60a5fa, #34d399);
  color: white;
  padding: 40px 20px 20px;
}

.footer-container {
  display: flex;
  justify-content: space-around;
  flex-wrap: wrap;
}

.footer-section {
  width: 250px;
  margin: 10px;
}

.footer-section h3 {
  margin-bottom: 15px;
}

.footer-section p,
.footer-section li {
  font-size: 14px;
  margin-bottom: 8px;
}

.footer-section ul {
  list-style: none;
  padding: 0;
}

.footer-section a {
  color: white;
  text-decoration: none;
}

.footer-section a:hover {
  text-decoration: underline;
}

.footer-bottom {
  text-align: center;
  margin-top: 20px;
  border-top: 1px solid rgba(255,255,255,0.3);
  padding-top: 10px;
  font-size: 14px;
}


</style>
